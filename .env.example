NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_DEFAULT_TEAM_ID=your-team-id

# LINE Login / LIFF
# LINE Developers コンソール (https://developers.line.biz/) で以下を設定:
#   - LINE Login チャネルの「コールバックURL」にデプロイ先URLを登録:
#     例: https://your-app.vercel.app/api/auth/line/callback
NEXT_PUBLIC_LIFF_ID=your-liff-id
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# セッション署名キー (未設定時は LINE_CHANNEL_SECRET を使用)
# SESSION_SECRET=your-random-secret-key

# Anthropic API (AI 機能)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Supabase Cloud (GitHub Actions マイグレーション用)
# GitHub Secrets に設定:
#   SUPABASE_ACCESS_TOKEN  — https://supabase.com/dashboard/account/tokens で発行
#   SUPABASE_PROJECT_REF   — Supabase プロジェクト設定の Reference ID
