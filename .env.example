# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_DEFAULT_TEAM_ID=your-team-id
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== LINE =====
NEXT_PUBLIC_LIFF_ID=your-liff-id
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ===== Email (Resend) =====
RESEND_API_KEY=your-resend-api-key

# ===== AI Provider (anthropic or modal) =====
AI_PROVIDER=modal

# Anthropic (AI_PROVIDER=anthropic のとき)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Modal + Gemma (AI_PROVIDER=modal のとき)
MODAL_API_URL=https://susumutomita--main.modal.run
MODAL_API_KEY=your-modal-api-key

# ===== Cron =====
CRON_SECRET=your-cron-secret

# ===== Supabase Cloud (GitHub Actions マイグレーション用) =====
# GitHub Secrets に設定:
#   SUPABASE_ACCESS_TOKEN  — https://supabase.com/dashboard/account/tokens で発行
#   SUPABASE_PROJECT_REF   — Supabase プロジェクト設定の Reference ID
