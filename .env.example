# ============================================================
# mound 環境変数
# .env.local にコピーして値を設定してください
# ============================================================

# --- Runtime ---
# 開発用ログイン (/dev, /api/dev) は development 環境でのみ有効
NODE_ENV=development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key

# --- LINE Login / LIFF ---
# LINE Developers コンソール (https://developers.line.biz/) で設定:
#   - LINE Login チャネルの「コールバックURL」にデプロイ先URLを登録:
#     例: https://your-app.vercel.app/api/auth/line/callback
NEXT_PUBLIC_LIFF_ID=your-liff-id
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# --- セキュリティ ---
# セッション署名キー (未設定時は LINE_CHANNEL_SECRET を使用)
SESSION_SECRET=your-random-secret-key

# RSVP / 招待トークン署名用 (HMAC-SHA256)
RSVP_TOKEN_SECRET=your-rsvp-token-secret
INVITATION_SECRET=your-invitation-secret

# --- サイトURL ---
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- Cron ジョブ認証 ---
CRON_SECRET=your-cron-secret

# --- Anthropic API (AI 機能、任意) ---
# ANTHROPIC_API_KEY=your-anthropic-api-key
