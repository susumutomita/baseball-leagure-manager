{
  "name": "mound",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter @match-engine/web dev",
    "build": "bun run --filter @match-engine/web build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "dependencies": {
    "zod": "^4.3.6"
  }
}
